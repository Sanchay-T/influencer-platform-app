{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev:ngrok",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/**/*.js": {
      "maxDuration": 300
    },
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/trial-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reset-monthly-usage",
      "schedule": "0 0 1 * *"
    }
  ]
}
